class Cliente:
    def __init__(self, cedula, nombre, telefono, direccion, tipo_cliente, tipo_atencion, cantidad, prioridad, fecha):
        self.cedula = int(cedula)
        self.nombre = nombre
        self.telefono = telefono
        self.direccion = direccion
        self.tipo_cliente = tipo_cliente
        self.tipo_atencion = tipo_atencion
        self.cantidad = cantidad
        self.prioridad = prioridad
        self.fecha = fecha

        self.valor_cita = self.obtener_valor_cita()
        self.valor_atencion = self.obtener_valor_atencion()
        self.total = self.calcular_valor_total()

    def obtener_valor_cita(self):
        valores = {
            "Particular": 80000,
            "EPS": 5000,
            "Medicina Prepagada": 30000
        }
        return valores.get(self.tipo_cliente, 0)

    def obtener_valor_atencion(self):
        tabla = {
            "Particular": {"Limpieza": 60000, "Calzas": 80000, "Extracción": 100000, "Diagnóstico": 50000},
            "EPS": {"Limpieza": 0, "Calzas": 40000, "Extracción": 40000, "Diagnóstico": 0},
            "Medicina Prepagada": {"Limpieza": 0, "Calzas": 10000, "Extracción": 10000, "Diagnóstico": 0}
        }
        return tabla.get(self.tipo_cliente, {}).get(self.tipo_atencion, 0)

    def calcular_valor_total(self):
        if self.tipo_atencion in ["Limpieza", "Diagnóstico"]:
            self.cantidad = 1
        return self.valor_cita + (self.valor_atencion * self.cantidad)

    def __str__(self):
        return f"{self.cedula} - {self.nombre} - Total: ${self.total}"

